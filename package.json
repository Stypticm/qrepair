{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "update-version": "node scripts/update-version.js",
    "version:patch": "node scripts/update-version.js patch",
    "version:minor": "node scripts/update-version.js minor",
    "version:major": "node scripts/update-version.js major",
    "prepare": "npm run update-version && git add . && git config --global core.autocrlf true",
    "precommit": "npm run update-version && git add . && git config --global core.autocrlf true && git add .",
    "deploy": "npm run update-version && git add . && git commit -m \"Update version for deployment\" && git push origin dev",
    "migrate-devices": "tsx scripts/migrate-devices-to-db.ts",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {

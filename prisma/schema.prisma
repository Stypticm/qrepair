generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Skupka {
  id          String       @id @default(cuid())
  telegramId  String
  username    String
  modelname   String?
  photoUrls   String[]
  videoUrl    String?
  status      SkupkaStatus @default(draft)
  comment     String?
  imei        String?
  contractUrl String?
  answers     Int[]        @default([0, 0, 0, 0, 0, 0, 0, 0])
  price       Float?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum SkupkaStatus {
  draft
  on_the_way
  in_progress
  accepted
  paid
  completed
}

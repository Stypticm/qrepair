generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Skupka {
  id                   String       @id @default(cuid())
  telegramId           String
  username             String
  modelname            String?
  photoUrls            String[]
  status               SkupkaStatus @default(draft)
  comment              String?
  imei                 String?
  sn                   String? // Серийный номер устройства
  contractUrl          String?
  price                Float?
  damagePercent        Float        @default(0)
  priceConfirmed       Boolean      @default(false)
  inspection           Json?
  inspectionCompleted  Boolean      @default(false)
  inspectionToken      String?
  deviceData           Json? // Данные устройства, получаемые через серийный номер
  phoneData            Json? // Данные выбранного телефона
  currentStep          String? // Текущий шаг в процессе
  courierTelegramId    String?
  courierScheduledAt   DateTime?
  courierTimeSlot      String?
  courierUserConfirmed Boolean      @default(false)
  courierReminderSent  Boolean      @default(false)
  courierTimeSlotSent  Boolean      @default(false)
  finalPrice           Float? // Окончательная цена после проверки
  deviceConditions     Json? // Детальное состояние устройства (front, back, side)
  additionalConditions Json? // Дополнительные условия (faceId, touchId, backCamera, battery)
  submittedAt          DateTime? // Время отправки заявки

  // Новые поля для переделанной страницы submit
  priceAgreed         Boolean? // Согласен ли пользователь с ценой
  feedback            String? // Отзыв пользователя если не согласен
  deliveryMethod      String? // 'pickup' или 'courier'
  pickupPoint         String? // Выбранная точка самовывоза
  courierAddress      String? // Адрес для курьера
  courierDate         DateTime? // Дата вызова курьера
  courierTime         String? // Время вызова курьера
  telegramIdConfirmed Boolean   @default(false) // Подтвердил ли пользователь свой Telegram ID
  userTelegramId      String? // Подтвержденный Telegram ID пользователя

  // Поля для мастеров
  assignedMasterId    String? // ID мастера, назначенного на заявку
  assignedMaster      Master? @relation(fields: [assignedMasterId], references: [id])
  aiAnalysis          Json? // Результат ИИ-анализа (заглушка)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  inspections DeviceInspection[]
}

model Master {
  id         String   @id @default(cuid())
  telegramId String   @unique
  username   String   @unique
  name       String?
  isActive   Boolean  @default(true)
  pointId    Int?     // Привязка к точке
  point      Point?   @relation(fields: [pointId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Связи
  inspections DeviceInspection[]
  assignedRequests Skupka[] // Заявки, назначенные мастеру
}

model Point {
  id           Int      @id @default(autoincrement())
  address      String   @unique
  workingHours String   @default("10:00 - 22:00")
  masters      Master[]
}

model DeviceInspection {
  id              String    @id @default(cuid())
  skupkaId        String // Связь с заявкой
  masterUsername  String // Username мастера
  inspectionToken String // OTP токен для проверки
  tokenExpiresAt  DateTime // Время истечения токена
  testsResults    Json // Результаты всех тестов
  finalPrice      Float? // Окончательная цена
  inspectionNotes String? // Заметки мастера
  completedAt     DateTime? // Время завершения
  createdAt       DateTime  @default(now())

  // Связи
  skupka Skupka  @relation(fields: [skupkaId], references: [id], onDelete: Cascade)
  master Master? @relation(fields: [masterUsername], references: [username], onDelete: Cascade)

  @@index([skupkaId])
  @@index([masterUsername])
  @@index([inspectionToken])
}

model Device {
  id        String @id @default(cuid())
  model     String // "iPhone 15 Pro"
  variant   String // "Max" или ""
  storage   String // "128GB", "256GB", etc.
  color     String // "Bl", "Wh", "Gold", etc.
  country   String // "Китай 🇨🇳", "США 🇺🇸", etc.
  simType   String // "1 SIM", "2 SIM"
  basePrice Float // Базовая цена в рублях

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  marketPrices MarketPrice[]

  // Индексы для быстрой фильтрации
  @@index([model])
  @@index([model, variant])
  @@index([model, variant, storage])
  @@index([model, variant, storage, color])
  @@index([country])
  @@index([simType])
  @@index([basePrice])
  
  // Уникальный индекс для предотвращения дубликатов
}

model MarketPrice {
  id          String   @id @default(cuid())
  deviceId    String   // Связь с устройством
  source      String   // "avito", "youla", "wildberries", etc.
  price       Float    // Цена с площадки
  url         String?  // Ссылка на объявление
  title       String?  // Заголовок объявления
  description String?  // Описание
  location    String?  // Город/регион
  condition   String?  // Состояние (новый, б/у, etc.)
  sellerType  String?  // Тип продавца (частник, магазин)
  parsedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Связи
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // Индексы
  @@index([deviceId])
  @@index([source])
  @@index([parsedAt])
  @@index([price])
  @@index([source, deviceId])
}

enum SkupkaStatus {
  draft
  submitted
  on_the_way
  in_progress
  accepted
  paid
  completed
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Skupka {
  id          String            @id @default(cuid())
  telegramId  String
  username    String
  modelname   String?
  condition   ConditionStatus[] @default([display, body])
  photoUrls   String[]
  videoUrl    String?
  status      SkupkaStatus      @default(draft)
  comment     String?
  imei        String?
  contractUrl String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum SkupkaStatus {
  draft
  on_the_way
  in_progress
  accepted
  paid
}

enum ConditionStatus {
  display
  display_with_damage
  body
  body_with_damage
}

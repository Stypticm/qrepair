generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Skupka {
  id                   String       @id @default(cuid())
  telegramId           String
  username             String
  modelname            String?
  photoUrls            String[]
  videoUrl             String?
  status               SkupkaStatus @default(draft)
  comment              String?
  imei                 String?
  contractUrl          String?
  answers              Int[]        @default([0, 0, 0, 0, 0, 0, 0, 0])
  price                Float?
  damagePercent        Float        @default(0)
  questionsAnswered    Boolean      @default(false)
  priceConfirmed       Boolean      @default(false)
  inspection           Json?
  inspectionCompleted  Boolean      @default(false)
  inspectionToken      String?
  imeiInfo             Json?
  courierTelegramId    String?
  courierScheduledAt   DateTime?
  courierTimeSlot      String?
  courierUserConfirmed Boolean      @default(false)
  courierReminderSent  Boolean      @default(false)
  courierTimeSlotSent  Boolean      @default(false)
  finalPrice           Float?       // Окончательная цена после проверки
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  
  // Связи
  inspections         DeviceInspection[]
}

model Master {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  username    String   @unique
  name        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Связи
  inspections DeviceInspection[]
}

model DeviceInspection {
  id                  String   @id @default(cuid())
  skupkaId            String   // Связь с заявкой
  masterUsername      String   // Username мастера
  inspectionToken     String   // OTP токен для проверки
  tokenExpiresAt      DateTime // Время истечения токена
  testsResults        Json     // Результаты всех тестов
  finalPrice          Float?   // Окончательная цена
  inspectionNotes     String?  // Заметки мастера
  completedAt         DateTime? // Время завершения
  createdAt           DateTime @default(now())
  
  // Связи
  skupka              Skupka   @relation(fields: [skupkaId], references: [id], onDelete: Cascade)
  master              Master?  @relation(fields: [masterUsername], references: [username])
  
  @@index([skupkaId])
  @@index([masterUsername])
  @@index([inspectionToken])
}

enum SkupkaStatus {
  draft
  on_the_way
  in_progress
  accepted
  paid
  completed
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Skupka {
  id                   String       @id @default(cuid())
  telegramId           String
  username             String
  modelname            String?
  photoUrls            String[]
  videoUrl             String?
  status               SkupkaStatus @default(draft)
  comment              String?
  imei                 String?
  contractUrl          String?
  answers              Int[]        @default([0, 0, 0, 0, 0, 0, 0, 0])
  price                Float?
  damagePercent        Float        @default(0)
  questionsAnswered    Boolean      @default(false)
  priceConfirmed       Boolean      @default(false)
  inspection           Json?
  inspectionCompleted  Boolean      @default(false)
  inspectionToken      String?
  imeiInfo             Json?
  courierTelegramId    String?
  courierScheduledAt   DateTime?
  courierTimeSlot      String?
  courierUserConfirmed Boolean      @default(false)
  courierReminderSent  Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

enum SkupkaStatus {
  draft
  on_the_way
  in_progress
  accepted
  paid
  completed
}

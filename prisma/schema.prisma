generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model Skupka {
  id         String       @id @default(cuid())
  telegramId String
  username   String
  modelname  String?
  imei       String?
  sn         String?
  status     SkupkaStatus @default(draft)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // 📸 медиа
  photoUrls String[]
  videoUrls String[]

  // 📊 данные устройства и анализа
  deviceData         Json? // из IMEICheck
  aiAnalysis         Json? // состояние, дефекты, цена
  priceRange         Json? // {min, max}
  aiModelUsed        String?
  analysisConfidence Float?
  chatHistory        Json? // ИИ-диалог с клиентом
  deviceConditions   Json? // структурированные дефекты

  // 💰 финансовая часть
  price            Float?
  finalPrice       Float?
  priceAgreed      Boolean?
  damagePercent    Float    @default(0)
  functionDiscount Float?   @default(0)

  // 🚚 логистика
  courier        Json? // {address, date, time, method, confirmed, courierId}
  deliveryMethod String?
  pickupPoint    String?

  // 📋 статусы
  currentStep          String?
  inspection           Json?
  inspectionCompleted  Boolean   @default(false)
  statusNote           String?
  submittedAt          DateTime?
  priceConfirmed       Boolean   @default(false)
  courierReminderSent  Boolean   @default(false)
  courierUserConfirmed Boolean   @default(false)

  // 💬 взаимодействие
  comment              String?
  feedback             String?
  userEvaluation       String?
  additionalConditions Json?
  telegramIdConfirmed  Boolean @default(false)
  userTelegramId       String?
  assignedMasterId     String?
  assignedMaster       Master? @relation(fields: [assignedMasterId], references: [id])

  // связи
  inspections DeviceInspection[]
  marketplaceLot MarketplaceLot?

  @@schema("public")
}

model Master {
  id               String             @id @default(cuid())
  telegramId       String             @unique
  username         String             @unique
  name             String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  pointId          Int?
  inspections      DeviceInspection[]
  point            Point?             @relation(fields: [pointId], references: [id])
  assignedRequests Skupka[]

  @@schema("public")
}

model Point {
  id           Int      @id @default(autoincrement())
  address      String   @unique
  workingHours String   @default("10:00 - 22:00")
  name         String   @default("Точка приёма")
  masters      Master[]
  orders       Order[]  // Заказы с самовывозом

  @@schema("public")
}

model DeviceInspection {
  id              String    @id @default(cuid())
  skupkaId        String
  inspectionToken String
  tokenExpiresAt  DateTime
  testsResults    Json
  finalPrice      Float?
  inspectionNotes String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  masterUsername  String
  master          Master    @relation(fields: [masterUsername], references: [username], onDelete: Cascade)
  skupka          Skupka    @relation(fields: [skupkaId], references: [id], onDelete: Cascade)

  @@index([skupkaId])
  @@index([masterUsername])
  @@index([inspectionToken])
  @@schema("public")
}

model Device {
  id           String        @id @default(cuid())
  model        String
  variant      String
  storage      String
  color        String
  country      String
  simType      String
  basePrice    Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  marketPrices MarketPrice[]

  @@index([model])
  @@index([model, variant])
  @@index([model, variant, storage])
  @@index([model, variant, storage, color])
  @@index([country])
  @@index([simType])
  @@index([basePrice])
  @@schema("public")
}

model MarketPrice {
  id          String   @id @default(cuid())
  deviceId    String
  source      String
  price       Float
  url         String?
  title       String?
  description String?
  location    String?
  condition   String?
  sellerType  String?
  parsedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([source])
  @@index([parsedAt])
  @@index([price])
  @@index([source, deviceId])
  @@schema("public")
}

enum SkupkaStatus {
  draft
  on_the_way
  in_progress
  accepted
  paid
  completed
  submitted
  inspected

  @@schema("public")
}

enum MarketplaceLotStatus {
  draft       // черновик
  available   // доступен для покупки
  reserved    // зарезервирован
  sold        // продан
  archived    // архивирован

  @@schema("public")
}

model MarketplaceLot {
  id           String   @id @default(cuid())
  skupkaId     String?  @unique // связь с заявкой (опционально)
  title        String
  model        String?
  storage      String?
  color        String?
  condition    String?
  description  String?
  price        Float
  photos       String[] // массив URL
  coverPhoto   String?  // обложка
  
  status       MarketplaceLotStatus @default(available)
  
  sellerId     String   // telegramId продавца
  sellerName   String?
  
  viewsCount   Int      @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  publishedAt  DateTime?
  soldAt       DateTime?
  
  // Связи
  skupka              Skupka?             @relation(fields: [skupkaId], references: [id], onDelete: Cascade)
  cartItems           CartItem[]
  favoriteItems       FavoriteItem[]
  orderItems          OrderItem[]         // Заказы с этим лотом
  
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([price])
  @@schema("public")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String   // telegramId пользователя
  lotId     String
  quantity  Int      @default(1)
  
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Связи
  lot       MarketplaceLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lotId]) // один лот = одна запись в корзине на пользователя
  @@index([userId])
  @@index([lotId])
  @@schema("public")
}

model FavoriteItem {
  id        String   @id @default(cuid())
  userId    String   // telegramId пользователя
  lotId     String
  
  addedAt   DateTime @default(now())
  
  // Связи
  lot       MarketplaceLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lotId]) // один лот = одна запись в избранном
  @@index([userId])
  @@index([lotId])
  @@schema("public")
}

enum OrderStatus {
  pending      // ожидает обработки
  confirmed    // подтвержден
  in_delivery  // в доставке
  completed    // завершен
  cancelled    // отменен

  @@schema("public")
}

model Order {
  id              String      @id @default(cuid())
  userId          String      // telegramId
  
  // Доставка
  deliveryMethod  String      // 'courier' | 'pickup'
  deliveryAddress String?     // для курьера
  pickupPointId   Int?        // для самовывоза
  pickupPoint     Point?      @relation(fields: [pickupPointId], references: [id])
  
  // Даты
  deliveryDate    DateTime?
  deliveryTime    String?
  
  // Статус и цена
  status          OrderStatus @default(pending)
  totalPrice      Float
  
  // Tracking
  confirmedAt     DateTime?
  inDeliveryAt    DateTime?
  completedAt     DateTime?
  
  // Курьер (опционально)
  courierName     String?
  courierPhone    String?
  trackingNotes   String?  // заметки админа
  
  // Связи
  items           OrderItem[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@schema("public")
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  lotId   String
  
  // Копируем данные лота на момент покупки
  title   String
  price   Float
  
  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lot     MarketplaceLot @relation(fields: [lotId], references: [id])

  @@index([orderId])
  @@index([lotId])
  @@schema("public")
}

model OperatorChat {
  id             String            @id @default(cuid())
  userTelegramId String            @unique
  userNickname   String?
  messages       OperatorMessage[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userTelegramId])
  @@schema("public")
}

model OperatorMessage {
  id         String       @id @default(cuid())
  chatId     String
  chat       OperatorChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId   String // telegramId отправителя
  senderType SenderType
  text       String
  createdAt  DateTime     @default(now())

  @@index([chatId])
  @@schema("public")
}

model AuthRequest {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status           String   @default("pending")
  telegramId       String?  @map("telegram_id")
  telegramUsername String?  @map("telegram_username")
  telegramData     Json?    @map("telegram_data")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("auth_requests")
  @@schema("public")
}

model User {
  id           String   @id @default(cuid())
  telegramId   String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([telegramId])
  @@index([role])
  @@schema("public")
}

enum Role {
  USER
  ADMIN
  MASTER
  MANAGER

  @@schema("public")
}

enum SenderType {
  user
  admin

  @@schema("public")
}
model QuickLead {
  id           String   @id @default(cuid())
  name         String
  phone        String
  productId    String?
  productTitle String?
  price        Float?
  telegramId   String?
  status       String   @default("new") // new, contacted, closed
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@schema("public")
}
model TradeInEvaluation {
  id               String   @id @default(cuid())
  userId           String   // telegramId
  category         String   @default("iPhone")
  model            String
  variant          String?
  storage          String
  color            String
  isOriginal       Boolean  @default(true)
  isReset          Boolean  @default(true)
  screenCondition  String   // perfect, good, worn, bad
  bodyCondition    String   // perfect, good, worn, bad
  isRostest        Boolean  @default(true)
  batteryHealth    String   // e.g. "100%", "80-99%", etc
  hasFullSet       Boolean  @default(true)
  wasRepaired      Boolean  @default(false)
  hasReceipt       Boolean  @default(false)
  
  // New functional checks
  isFunctional     Boolean  @default(true) // Включается и заряжается
  isBatterySafe    Boolean  @default(true) // Не вздутый
  isHardwareOk     Boolean  @default(true) // FaceID, WiFi, Sim и т.д.
  isClean          Boolean  @default(true) // Без ржавчины/окисления
  
  calculatedPrice  Float
  minPrice         Float?
  maxPrice         Float?
  status           String   @default("draft")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@schema("public")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?  // telegramId (optional, if we want to link to user)
  endpoint  String   @unique
  p256dh    String
  auth      String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@schema("public")
}
